generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  userId      String   @map("user_id")
  id          String
  items       Json
  totalAmount Decimal  @map("total_amount") @db.Decimal(14, 2)
  status      String
  createdAt   DateTime @map("created_at")

  @@id([userId, id])
  @@index([userId, createdAt(sort: Desc)])
  @@map("orders")
}
